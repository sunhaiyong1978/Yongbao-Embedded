source env/host-tools/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=host-tools
export STEP_PACKAGENAME=tcl
export PACKAGE_VERSION=8.6.13
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/host-tools/tcl/8.6.13/
rm -rf ${BUILD_DIRECTORY}/tcl8.6.13
tar xvf ${DOWNLOADDIR}/tcl8.6.13-src.tar.gz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/tcl8.6.13
    TCL_VERSION="${PACKAGE_VERSION%\.*}"
    SRCDIR=$(pwd)
    pushd unix
	    ./configure --prefix=${PREFIX} --libdir=${PREFIX}/lib${LIB_SUFF}
	    make -j${JOBS}
	    make install
	    make install-private-headers
	    ln -sfv tclsh${TCL_VERSION} ${PREFIX}/bin/tclsh
    popd
popd 
rm -rf ${BUILD_DIRECTORY}/tcl8.6.13
