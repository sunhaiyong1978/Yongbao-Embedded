+.file "ontop_loongarch32_sysv_elf_gas.S"
+.text
+.globl ontop_fcontext
+.hidden ontop_fcontext
+.align 2
+.type ontop_fcontext,@function
+ontop_fcontext:
+    # reserve space on stack
+    addi.w  $sp, $sp, -160
+
+    # save fs0 - fs7
+    fst.s  $fs0, $sp, 0
+    fst.s  $fs1, $sp, 8
+    fst.s  $fs2, $sp, 16
+    fst.s  $fs3, $sp, 24
+    fst.s  $fs4, $sp, 32
+    fst.s  $fs5, $sp, 40
+    fst.s  $fs6, $sp, 48
+    fst.s  $fs7, $sp, 56
+
+    # save s0 - s8, fp, ra
+    st.w  $s0, $sp, 64
+    st.w  $s1, $sp, 72
+    st.w  $s2, $sp, 80
+    st.w  $s3, $sp, 88
+    st.w  $s4, $sp, 96
+    st.w  $s5, $sp, 104
+    st.w  $s6, $sp, 112
+    st.w  $s7, $sp, 120
+    st.w  $s8, $sp, 128
+    st.w  $fp, $sp, 136
+    st.w  $ra, $sp, 144
+
+    # save RA as PC
+    st.w  $ra, $sp, 152
+
+    # store SP (pointing to context-data) in A3
+    move  $a3, $sp
+
+    # restore SP (pointing to context-data) from A0
+    move  $sp, $a0
+
+    # load fs0 - fs11
+    fld.s  $fs0, $sp, 0
+    fld.s  $fs1, $sp, 8
+    fld.s  $fs2, $sp, 16
+    fld.s  $fs3, $sp, 24
+    fld.s  $fs4, $sp, 32
+    fld.s  $fs5, $sp, 40
+    fld.s  $fs6, $sp, 48
+    fld.s  $fs7, $sp, 56
+
+    #load s0 - s11, fp, ra
+    ld.w  $s0, $sp, 64
+    ld.w  $s1, $sp, 72
+    ld.w  $s2, $sp, 80
+    ld.w  $s3, $sp, 88
+    ld.w  $s4, $sp, 96
+    ld.w  $s5, $sp, 104
+    ld.w  $s6, $sp, 112
+    ld.w  $s7, $sp, 120
+    ld.w  $s8, $sp, 128
+    ld.w  $fp, $sp, 136
+    ld.w  $ra, $sp, 144
+
+    # return transfer_t from jump
+    # pass transfer_t as first arg in context function
+    # a0 == FCTX, a1 == DATA
+    move  $a0, $a3
+
+    # adjust stack
+    addi.w  $sp, $sp, 160
+
+    # jump to context
+    jr  $a2
+.size ontop_fcontext, .-ontop_fcontext
