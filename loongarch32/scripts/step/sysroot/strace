source env/sysroot/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=sysroot
export STEP_PACKAGENAME=strace
export PACKAGE_VERSION=6.19
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/sysroot/strace/6.19/
rm -rf ${BUILD_DIRECTORY}/strace-6.19
tar xvf ${DOWNLOADDIR}/strace-6.19.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/strace-6.19
	
	for config_i in $(find -name "config.sub")
	do
		cp -a -f ${CROSSTOOLS_DIR}/share/automake*/config.* $(dirname ${config_i})/
	done
	if [ ! -f configure ]; then
		autoreconf -ifv
	fi
	 ./configure ${COMMON_CONFIG} CFLAGS="${CFLAGS} -Wno-error=calloc-transposed-args -Wno-error=sign-compare" --enable-malloc0returnsnull
	CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" make -j${JOBS}
        make DESTDIR=${SYSROOT_DIR} install
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
popd 
rm -rf ${BUILD_DIRECTORY}/strace-6.19
