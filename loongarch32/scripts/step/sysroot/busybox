source env/sysroot/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=sysroot
export STEP_PACKAGENAME=busybox
export PACKAGE_VERSION=1.38.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/sysroot/busybox/1.38.0/
rm -rf ${BUILD_DIRECTORY}/busybox-1.38.0
tar xvf ${DOWNLOADDIR}/busybox-1.38.0.tar.bz2 -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/busybox-1.38.0
    
    make mrproper
    make defconfig
    sed -i "/^# CONFIG_STATIC=/d" .config
    echo "CONFIG_STATIC=y" >> .config
    sed -i "/CONFIG_TC=y/s@=y@=n@g" .config
    make -j${JOBS} CROSS_COMPILE=${CROSS_TARGET}-
    cp -v busybox ${SYSROOT_DIR}/usr/bin/
popd 
rm -rf ${BUILD_DIRECTORY}/busybox-1.38.0
