source env/sysroot/config
source env/distro.info
source env/function.sh
export STEP_BUILDNAME=sysroot
export STEP_PACKAGENAME=gawk
export PACKAGE_VERSION=5.4.0
export RESOURCEDIR=${NEW_TARGET_SYSDIR}/files/sysroot/gawk/5.4.0/
rm -rf ${BUILD_DIRECTORY}/gawk-5.4.0
tar xvf ${DOWNLOADDIR}/gawk-5.4.0.tar.xz -C ${BUILD_DIRECTORY} 
pushd ${BUILD_DIRECTORY}/gawk-5.4.0
	patch -Np1 -i ${SYSDIR}/files/sysroot/gawk/5.4.0/patches/0001-set-has_f_format-yes-when-cross_compiling.patch 
	 
	sed -i 's/extras//' Makefile.in
	./configure --prefix=/usr  --libdir=/usr/lib${LIB_SUFF} --build=${CROSS_HOST} --host=${CROSS_TARGET}
	eval ${MAKE_AND_INSTALL}
popd 
rm -rf ${BUILD_DIRECTORY}/gawk-5.4.0
